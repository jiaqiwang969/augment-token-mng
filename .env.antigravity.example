# Local-only Antigravity OAuth credentials.
# Prefer `make antigravity-env-bootstrap` if your local env or trusted git history already has the real values.
# `make antigravity-env-check` validates setup without printing the secrets.

ATM_ANTIGRAVITY_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
ATM_ANTIGRAVITY_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret

# Legacy CLIProxy variable names remain supported for compatibility only:
# CLIPROXY_ANTIGRAVITY_OAUTH_CLIENT_ID=
# CLIPROXY_ANTIGRAVITY_OAUTH_CLIENT_SECRET=
