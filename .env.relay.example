# Remote relay deployment settings for `make deploy`

ATM_RELAY_HOST=ubuntu@your-relay-host
ATM_RELAY_SERVER_NAME=relay.example.com
ATM_RELAY_PUBLIC_BASE_URL=https://relay.example.com/v1
ATM_RELAY_REMOTE_PORT=19090
ATM_RELAY_LOCAL_PORT=8766
ATM_RELAY_NGINX_SITE_PATH=/etc/nginx/sites-enabled/your-site
ATM_RELAY_API_KEY=sk-your-public-gateway-key

# Optional overrides
# ATM_RELAY_CONTROL_SOCKET=/Users/you/.ssh/atm-relay-19090.sock
# ATM_RELAY_LOCAL_BASE_URL=http://127.0.0.1:8766/v1
# ATM_RELAY_REMOTE_TMP_PATH=/tmp/atm-relay-nginx.conf
# ATM_RELAY_NGINX_VALIDATE_COMMAND=sudo nginx -t
# ATM_RELAY_NGINX_RELOAD_COMMAND=sudo systemctl reload nginx
